  "M122.75 127.62c-14.23 11.03-28.21 20.53-40.43 27.67 7.48 4 16.02 6.26 25.08 6.26 29.55 0 53.5-24.04 53.5-53.69 0-4.24-.49-8.37-1.42-12.34-9.95 10.03-22.57 21.13-36.73 32.1Z";
---

<section class="mb-12 sm:mb-14 bg-white/45 border border-[#2d2a26]/5 p-5 sm:p-8 md:p-10 relative overflow-hidden rounded-2xl">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 md:gap-12 items-center">
    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-2">
        <p class="text-[10px] sm:text-[11px] font-serif font-bold uppercase tracking-[0.22em] text-orange-900/80">
          Connect
        </p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight">{site.sections.rssTitle}</h2>
      </div>
      <p class="text-sm md:text-base text-[#6f685f] leading-relaxed font-serif max-w-md">
        {site.sections.rssDescription}
      </p>
      <div class="flex flex-wrap gap-3 sm:gap-6 pt-2 sm:pt-3">
        <a
          href={site.podcast.appleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-xs font-serif font-bold uppercase tracking-widest hover:text-orange-700 transition-colors"
        >
          <svg viewBox="0 0 24 24" class="size-4 sm:size-5" fill="currentColor">
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
          {site.sections.rssLabels.apple}
        </a>
        <a
          href={site.podcast.rssUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-xs font-serif font-bold uppercase tracking-widest hover:text-orange-700 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 sm:size-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"
            ></path>
          </svg>
          {site.sections.rssLabels.rss}
        </a>
        <a
          href={site.podcast.xiaoyuzhouUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-xs font-serif font-bold uppercase tracking-widest hover:text-orange-700 transition-colors"
        >
          <svg
            viewBox="0 0 214 214"
            class="size-4 sm:size-5"
            aria-hidden="true"
            fill="none"
          >
            <path d={xiaoyuzhouLogoPath} fill="#231f20"></path>
            <path d={xiaoyuzhouLogoSubPath} fill="#231f20"></path>
          </svg>
          <span>{site.sections.rssLabels.xiaoyuzhou}</span>
        </a>
      </div>
    </div>

    <div class="relative flex justify-center md:justify-end">
      <div class="flex w-full max-w-sm md:max-w-none flex-nowrap justify-center md:justify-end gap-3 sm:gap-4">
        <div class="text-center flex-1 min-w-0 max-w-44">
          <div
            class="w-full rounded-2xl border border-[#2d2a26]/5 bg-white/80 p-3 sm:p-4 shadow-[0_18px_40px_-28px_rgba(0,0,0,0.32)] backdrop-blur-sm"
          >
            <div class="mb-3 flex items-center justify-center gap-2 text-[#2d2a26]">
              <svg viewBox="0 0 214 214" class="size-4" aria-hidden="true" fill="none">
                <path d={xiaoyuzhouLogoPath} fill="#231f20"></path>
                <path d={xiaoyuzhouLogoSubPath} fill="#231f20"></path>
              </svg>
              <p class="text-[11px] font-serif font-bold uppercase tracking-[0.2em] text-[#5f584f]">
                {site.sections.rssLabels.xiaoyuzhou}
              </p>
            </div>
            <div
              class="aspect-square mb-3 flex items-center justify-center bg-white bg-cover bg-center rounded-xl overflow-hidden p-2"
              style={`background-image: url('${site.podcast.xiaoyuzhouQr}')`}
            >
            </div>
            <p
              class="text-[10px] font-serif text-[#726a61] uppercase tracking-[0.2em] font-bold"
            >
              扫码收听
            </p>
          </div>
        </div>
        <div class="text-center flex-1 min-w-0 max-w-44">
          <div
            class="w-full rounded-2xl border border-[#2d2a26]/5 bg-white/80 p-3 sm:p-4 shadow-[0_18px_40px_-28px_rgba(0,0,0,0.32)] backdrop-blur-sm"
          >
            <div class="mb-3 flex items-center justify-center gap-2 text-[#2d2a26]">
              <svg viewBox="0 0 1024 1024" class="size-4" fill="currentColor">
                <path d="M682.666667 362.666667C682.666667 225.28 554.666667 114.346667 396.8 114.346667c-157.866667 0-285.866667 110.933333-285.866667 248.32 0 76.8 39.253333 145.066667 101.12 191.573333l-26.453333 80.64 87.893333-43.946667c37.546667 10.666667 78.506667 17.066667 123.306667 17.066667 18.773333 0 37.12-1.28 55.04-3.84-2.56-11.52-3.84-23.466667-3.84-35.84 0-149.333333 133.546667-270.506667 298.666667-270.506667 11.946667 0 24.32 0.853333 35.84 2.56z m-165.12-62.72c20.48 0 37.12 16.64 37.12 37.12s-16.64 37.12-37.12 37.12-37.12-16.64-37.12-37.12 16.64-37.12 37.12-37.12z m-222.72 0c20.48 0 37.12 16.64 37.12 37.12s-16.64 37.12-37.12 37.12-37.12-16.64-37.12-37.12 16.64-37.12 37.12-37.12z" />
                <path d="M1024 645.12c0-117.76-110.933333-213.333333-248.32-213.333333-137.386667 0-248.32 95.573333-248.32 213.333333 0 117.76 110.933333 213.333333 248.32 213.333333 34.56 0 67.413333-6.4 96.853333-17.066667l67.84 34.133333-20.48-62.293333c48.213333-40.106667 79.36-93.866667 79.36-151.04z m-338.346667-34.133333c-15.36 0-27.733333-12.373333-27.733333-27.733333s12.373333-27.733333 27.733333-27.733333 27.733333 12.373333 27.733333 27.733333-12.373333 27.733333-27.733333 27.733333z m181.333334 0c-15.36 0-27.733333-12.373333-27.733333-27.733333s12.373333-27.733333 27.733333-27.733333 27.733333 12.373333 27.733333 27.733333-12.373333 27.733333-27.733333 27.733333z" />
              </svg>
              <p class="text-[11px] font-serif font-bold uppercase tracking-[0.2em] text-[#5f584f]">
                {site.sections.rssLabels.wechat}
              </p>
            </div>
            <div
              class="aspect-square mb-3 flex items-center justify-center bg-white bg-cover bg-center rounded-xl overflow-hidden p-2"
              style={`background-image: url('${site.podcast.wechatQr}')`}
            >
            </div>
            <p
              class="text-[10px] font-serif text-[#726a61] uppercase tracking-[0.2em] font-bold"
            >
              扫码关注
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
