---
// 订阅平台链接与二维码都在 site.json 中维护。
import site from "../data/site.json";

const xiaoyuzhouLogoPath =
  "M177.21 60.22c-.38 2.18-1.32 4.46-2.53 6.69-2.43 4.51-6.48 9.86-11.63 15.67-10.37 11.67-25.9 25.92-44.12 40.04-18.22 14.12-35.88 25.59-49.75 32.71-6.91 3.54-13.09 6.12-18.04 7.34-2.46.61-4.9.95-7.1.77-2.19-.19-4.79-.97-6.56-3.27-1.25-1.62-1.54-3.47-1.48-4.99.06-1.49.46-2.95.96-4.26 1.01-2.61 2.76-5.54 4.85-8.53 3.69-5.25 8.95-11.41 14.8-17.64-1.76-5.31-2.71-10.99-2.71-16.89 0-29.65 23.96-53.69 53.5-53.69 10.44 0 20.17 3 28.4 8.18 8.89-5.1 16.86-8.9 23.15-10.93 3.18-1.02 6.21-1.68 8.86-1.7 2.53-.02 5.8.56 7.91 3.31 1.77 2.29 1.87 5.02 1.49 7.19Zm-9.36-1.09c-1.29.02-3.28.37-6.03 1.26-4.67 1.5-10.78 4.28-17.93 8.21q2.75 2.57 5.12 5.5c-9.54 10.36-23.45 23.01-39.92 35.77-16.55 12.83-32.35 23.18-44.77 29.83q-1.96-2.67-3.59-5.57c-4.54 4.99-8.45 9.7-11.24 13.68-1.83 2.61-3.04 4.71-3.67 6.24.76-.05 1.78-.2 3.08-.53 3.93-.96 9.36-3.16 16.01-6.57 13.22-6.78 30.38-17.91 48.29-31.78 17.9-13.88 32.96-27.74 42.84-38.86 4.97-5.59 8.46-10.31 10.39-13.88.77-1.44 1.21-2.53 1.42-3.3Z";
