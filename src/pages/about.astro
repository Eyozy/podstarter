---
import MainLayout from "../layouts/MainLayout.astro";
// 关于页内容在 site.json 的 about 字段中配置。
import site from "../data/site.json";

const { about } = site;
---

<MainLayout title={site.pages.about.title}>
  <section class="max-w-4xl mb-12 md:mb-16">
    <p class="text-[10px] md:text-[11px] font-serif font-bold uppercase tracking-[0.24em] text-orange-800/60 mb-3">
      About
    </p>
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[#2d2a26] mb-4 md:mb-6">{about.title}</h1>
    <p class="text-base md:text-lg opacity-60 font-serif leading-relaxed max-w-3xl">
      {about.tagline}
    </p>
  </section>

    <section class="mb-12 md:mb-16">
      <div class="max-w-3xl">
        <p class="text-base sm:text-lg font-serif leading-relaxed opacity-80">
          {about.intro}
        </p>
      </div>
    </section>

    <section class="mb-12 md:mb-16">
      <h2 class="text-xl sm:text-2xl font-bold mb-8 md:mb-10 flex items-center gap-3 sm:gap-4">
        <span class="w-12 h-px bg-[#2d2a26]/20"></span>
        {about.membersTitle}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5 md:gap-6">
        {
          about.members.map((member) => (
            <div class="bg-white/65 border border-[#2d2a26]/5 rounded-2xl px-5 py-5 md:px-6 md:py-6 shadow-[0_12px_26px_-24px_rgba(0,0,0,0.18)]">
              <h3 class="text-lg sm:text-xl font-bold mb-3">{member.name}</h3>
              <div class="flex flex-wrap gap-x-4 gap-y-2">
                {member.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs sm:text-sm font-serif font-bold text-[#2d2a26] hover:text-orange-700 relative pb-1 transition-colors duration-300 group"
                  >
                    {link.label}
                    <span class="absolute bottom-0 left-0 w-0 h-px bg-orange-700 transition-all duration-300 ease-out group-hover:w-full" />
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-5 md:gap-6">
      <div class="bg-white/55 p-6 sm:p-8 border border-[#2d2a26]/5 shadow-[0_14px_30px_-24px_rgba(0,0,0,0.2)] rounded-2xl">
        <h2 class="text-lg sm:text-xl font-bold mb-3 sm:mb-4">{about.contact.title}</h2>
        <p class="text-sm opacity-60 font-serif mb-5 sm:mb-6 leading-relaxed max-w-md">
          {about.contact.description}
        </p>
        <a
          href={`mailto:${about.contact.email}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-lg sm:text-2xl font-bold text-orange-800 relative inline-block group hover:text-orange-900 transition-colors duration-300 break-all"
        >
          {about.contact.email}
          <span
            class="absolute bottom-0 left-0 w-0 h-px bg-orange-800 transition-all duration-300 ease-out group-hover:w-full"
          ></span>
        </a>
      </div>

      <div class="bg-white/55 p-6 sm:p-8 border border-[#2d2a26]/5 shadow-[0_14px_30px_-24px_rgba(0,0,0,0.2)] rounded-2xl">
        <h2 class="text-lg sm:text-xl font-bold mb-3 sm:mb-4">{about.feedback.title}</h2>
        <p
          class="text-sm opacity-60 font-serif mb-6 sm:mb-7 leading-relaxed"
        >
          {about.feedback.description}
        </p>
        {about.feedback.formUrl && (
          <div class={about.feedback.channels && about.feedback.channels.length > 0 ? "mb-8 sm:mb-10" : ""}>
            <a
              href={about.feedback.formUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center w-full sm:w-auto px-6 py-3 bg-[#2d2a26] text-[#f4f3ef] rounded-xl font-bold text-sm sm:text-base hover:bg-orange-800 transition-colors duration-300 shadow-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              {about.feedback.formButtonText || "填写反馈表单"}
            </a>
          </div>
        )}

        {about.feedback.channels && about.feedback.channels.length > 0 && (
          <div>
            {about.feedback.formUrl && (
              <p class="text-xs sm:text-sm opacity-50 font-serif mb-4">其他反馈方式：</p>
            )}
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-8">
              {
                about.feedback.channels.map((channel: any) => (
                  <div>
                    <h3 class="text-base sm:text-lg font-bold mb-2.5">{channel.title}</h3>
                    <a
                      href={channel.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm sm:text-base font-serif text-[#2d2a26] hover:text-orange-700 relative pb-1 transition-colors duration-300 group"
                    >
                      {channel.label}
                      <span
                        class="absolute bottom-0 left-0 w-0 h-px bg-orange-700 transition-all duration-300 ease-out group-hover:w-full"
                      ></span>
                    </a>
                  </div>
                ))
              }
            </div>
          </div>
        )}
      </div>
    </section>
</MainLayout>
