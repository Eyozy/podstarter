---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import RSSSection from "../components/RSSSection.astro";
import episodes from "../data/episodes.json";
// 首页区块标题文案在 site.json 中配置。
import site from "../data/site.json";

// 跳过 Hero 使用的第一集，展示近期更新
const recentEpisodes = episodes.slice(1, 6);
---

<MainLayout title={site.pages.home.title}>
  <Hero />

  <section class="mb-14 md:mb-16">
    <div
      class="flex items-end justify-between gap-4 sm:gap-6 mb-8 md:mb-12 border-b border-[#2d2a26]/10 pb-5"
    >
      <div class="space-y-2">
        <p class="text-[10px] md:text-[11px] font-serif font-bold uppercase tracking-[0.24em] text-orange-900/80">
          {site.sections.recentSubtitle}
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-4xl font-bold tracking-tight">{site.sections.recentTitle}</h2>
      </div>
      <a
        href="/episodes"
        class="shrink-0 text-sm font-serif relative group py-1.5 text-[#5f584f] hover:text-[#2d2a26] transition-colors whitespace-nowrap"
      >
        <span class="relative z-10">{site.sections.recentBrowseAllLabel}</span>
        <span
          class="absolute bottom-0 left-0 w-0 h-px bg-orange-700 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
    </div>

    <div class="space-y-4 md:space-y-5">
      {
        recentEpisodes.map((episode) => (
          <EpisodeCard episode={episode} />
        ))
      }
    </div>
  </section>

  <RSSSection />
</MainLayout>
